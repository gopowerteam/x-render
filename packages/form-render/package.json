  "author": {
    "name": "zhuchentong",
    "email": "2037630@gmail.com"
  },
  "license": "MIT",
  "homepage": "https://github.com/gopowerteam/x-render",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gopowerteam/x-render.git"
  },
  "bugs": {
    "url": "https://github.com/gopowerteam/x-render/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/es/index.d.ts",
      "require": "./dist/cjs/index.cjs",
      "import": "./dist/es/index.mjs"
    },
    "./es": {
      "types": "./dist/es/index.d.ts",
      "import": "./dist/es/index.mjs"
    },
    "./cjs": {
      "types": "./dist/cjs/index.d.ts",
      "require": "./dist/cjs/index.cjs"
    },
    "./dist/style.css": {
      "require": "./dist/style.css",
      "import": "./dist/style.css"
    },
    "./*": "./*"
  },
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/es/index.mjs",
  "types": "./dist/es/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "npm:publish": "npm run build && npm publish --access publish"
  },
  "peerDependencies": {
    "@arco-design/web-vue": "^2.56.3",
    "@gopowerteam/modal-render": "^0.0.48",
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "@arco-design/web-vue": "2.56.3",
    "@gopowerteam/modal-render": "workspace:*",
    "@iconify-json/icon-park-outline": "^1.2.4",
    "@types/node": "18.16.0",
    "@unocss/preset-icons": "^66.6.3",
    "@unocss/preset-uno": "^66.6.3",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitejs/plugin-vue-jsx": "^5.1.4",
    "@vue/compiler-sfc": "^3.5.29",
    "@vueuse/core": "^14.2.1",
    "less": "^4.5.1",
    "typescript": "^5.9.3",
    "unocss": "^66.6.2",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vue": "^3.5.29",
    "vue-tsc": "^3.2.5"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  }
}
